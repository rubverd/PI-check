# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.log

# Environment / secrets
.env
.env.*
!.env.example
!backend/.env.example

# Android / Gradle
mobile/.gradle/
mobile/build/
mobile/app/build/
mobile/local.properties
.gradle/
build/
*/build/
local.properties
*.iml

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# APKs and downloaded datasets
*.apk
*.xapk
*.apks
*.apkm
apks/
downloads/
results/
/data/
!backend/artifacts/apks/
backend/artifacts/apks/*
!backend/artifacts/apks/.gitkeep
backend/artifacts/manual_uploads/*
!backend/artifacts/manual_uploads/.gitkeep

# PI-check generated artifacts
backend/artifacts/tmp/apks/
backend/artifacts/tmp/uploads/*
!backend/artifacts/tmp/uploads/.gitkeep
backend/artifacts/reports/mobsf/
backend/artifacts/reports/mastg/
backend/artifacts/reports/comparisons/

# Local nginx/certificate material generated by bootstrap scripts.
# Never commit private keys, CSRs or serial files. Public CA copies may exist
# locally, but should only be committed intentionally when rotating the app CA.
nginx/certs/**/*.key
nginx/certs/**/*.csr
nginx/certs/**/*.srl
nginx/certs/**/*.pem
nginx/certs/**/*.p12
nginx/certs/*.crt
nginx/certs/picheck-server.key
nginx/certs/picheck-server.csr
nginx/certs/picheck-server.srl
nginx/certs/picheck-server.crt
nginx/certs/picheck-server.cnf
nginx/certs/picheck-server.openssl.cnf
nginx/certs/server.crt
nginx/certs/server_cert.cnf
nginx/certs/backup_*/
# PI-check generated artifacts
/backend/artifacts/comparisons/*.json
/backend/artifacts/public/icons/**
/backend/artifacts/reports/mastg/**
/backend/artifacts/tmp/**
/backend/artifacts/manual_uploads/**
/backups/db/*.sql

# Local snapshots
/backend_tree.txt
/docs/dev_snapshots/*.txt

!/backend/artifacts/apks/.gitkeep
!/backend/artifacts/manual_uploads/.gitkeep
!/backend/artifacts/tmp/uploads/.gitkeep/docs/dev_samples/
