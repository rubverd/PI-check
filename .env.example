# PostgreSQL
POSTGRES_USER=picheck
POSTGRES_PASSWORD=picheck
POSTGRES_DB=picheck
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+psycopg://picheck:picheck@postgres:5432/picheck

# MobSF
MOBSF_URL=http://mobsf:8000
MOBSF_HOST_PORT=8000
MOBSF_API_KEY=picheck
MOBSF_TIMEOUT_SECONDS=600
MAX_APK_SIZE_MB=300
MAX_UPLOAD_APK_SIZE_MB=300
MOBSF_ANALYSIS_MODE=sync
MOBSF_MAX_PARALLEL_ANALYSES=2

# PI-check networking
PICHECK_API_PORT=8088
PICHECK_HTTPS_PORT=8443
PICHECK_PUBLIC_BASE_URL=https://virtual.lab.inf.uva.es:20492

# Storage inside backend container
APK_TMP_DIR=/app/artifacts/tmp/apks
APK_UPLOAD_STAGING_DIR=/app/artifacts/tmp/uploads
APK_STORAGE_DIR=/app/artifacts/apks
MANUAL_APK_UPLOAD_DIR=/app/artifacts/manual_uploads
MOBSF_REPORTS_DIR=/app/artifacts/reports/mobsf
MASTG_REPORTS_DIR=/app/artifacts/reports/mastg
COMPARISON_REPORTS_DIR=/app/artifacts/reports/comparisons
COMPARISON_ARTIFACTS_DIR=/app/artifacts/comparisons
KEEP_APKS_AFTER_ANALYSIS=true
